<!DOCTYPE html>
<html>
<head>
  <title>EJS Example</title>
</head>
<body>
   <!-- HEADER SECTION -->
    <section class="hero">
  <div class="overlay"></div>

  <div class="hero-content">
    <h1>Qualified Car Repair <br> Service Center</h1>
    <button class="btn-custom">Book Service</button>
  </div>
</section>

<!-- SERVICE SECTION -->
 <section class="services-section">
  <div class="container">
    <h2 class="section-title text-center">Our Car Services</h2>

    <div class="services-grid">
      <% const services = [
        { title: "Engine Repair", desc: "Complete engine diagnostics and repair", icon: "🔧" },
        { title: "Oil Change", desc: "High-quality engine oil replacement", icon: "🛢️" },
        { title: "Tire Service", desc: "Tire replacement and alignment", icon: "🛞" },
        { title: "Battery Check", desc: "Battery inspection and replacement", icon: "🔋" },
        { title: "Car Wash", desc: "Interior and exterior cleaning", icon: "🧽" },
        { title: "General Service", desc: "Complete car maintenance package", icon: "⚙️" },
        { title: "AC Service", desc: "Air conditioning maintenance and repair", icon: "❄️" },
        { title: "Brake Service", desc: "Brake check and replacement", icon: "🛑" }
      ]; %>

      <% services.forEach(service => { %>
        <div class="service-card">
          <div class="service-icon"><%= service.icon %></div>
          <h3><%= service.title %></h3>
          <p><%= service.desc %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ABOUT SECTION -->
 <section class="about-section">
  <div class="container">


    <h2 class="about-title text-center">About Us</h2>

    <div class="about-wrapper">


      <div class="about-img">
        <img src="https://images.unsplash.com/photo-1619642751034-765dfdf7c58e" alt="Car Repair">
       
      </div>

      <div class="about-content">

        <h4>Quality Service</h4>
        <p>
          We provide top-quality car repair and maintenance services 
          to keep your vehicle running smoothly.
        </p>

        <h4>Expert Mechanics</h4>
        <p>
          Our team consists of skilled professionals with years of experience.
        </p>

        <h4>Modern Equipment</h4>
        <p>
          We use the latest tools and technology for efficient service.
        </p>

        <a href="/contact" class="about-btn">Contact Us</a>

      </div>

    </div>

  </div>
</section>


<!-- tam section -->

<section class="team-section">
  <div class="container text-center">
    <h2 class="section-title">Our Team</h2>

    <div class="team-grid">

      <div class="team-card">
        <img src="https://images.unsplash.com/photo-1607746882042-944635dfe10e" alt="">
        <h3>Vishal Rawat</h3>
        <p>CEO & Founder</p>
      </div>

      <div class="team-card">
        <img src="https://images.unsplash.com/photo-1580489944761-15a19d654956" alt="">
        <h3>Jane Doe</h3>
        <p>Customer Service Manager</p>
      </div>

      <div class="team-card">
        <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e" alt="">
        <h3>Jane Smith</h3>
        <p>Chief Mechanic</p>
      </div>

      <div class="team-card">
        <img src="https://images.unsplash.com/photo-1556157382-97eda2d62296" alt="">
        <h3>Rahul Sharma</h3>
        <p>Technician</p>
      </div>

      <div class="team-card">
        <img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2" alt="">
        <h3>Priya Verma</h3>
        <p>Support Executive</p>
      </div>

    </div>
  </div>
</section>



<!-- clietn review -->


<section class="testimonial-section">
  <div class="container text-center">
    <h2 class="section-title">What Our Clients Say</h2>

    <div class="testimonial-grid">

      <!-- Card 1 -->
      <div class="testimonial-card">
        <img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2" alt="">
        <p>
          Great service! My car was fixed quickly and the staff was very friendly.
        </p>
        <h4>Baby Doe</h4>
      </div>

      <!-- Card 2 -->
      <div class="testimonial-card">
        <img src="https://images.unsplash.com/photo-1524504388940-b1c1722653e1" alt="">
        <p>
          I highly recommend this auto care center. They are professional and affordable.
        </p>
        <h4>Emma Stone</h4>
      </div>

      <!-- Card 3 -->
      <div class="testimonial-card">
        <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e" alt="">
        <p>
          The team is knowledgeable and efficient. I will definitely be back again.
        </p>
        <h4>Michael Johnson</h4>
      </div>

      <!-- Card 4 -->
      <div class="testimonial-card">
        <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330" alt="">
        <p>
          Excellent customer service and quality work. Very satisfied!
        </p>
        <h4>Emily Davis</h4>
      </div>

    </div>
  </div>
</section>






<!-- BANNER SECTION  -->

<section class="hero-section">
  <div class="hero-overlay"></div>

  <div class="container">
    <div class="hero-content">

      <span class="hero-tag">Trusted Auto Care</span>

      <h1>Certified and Experienced Mechanics</h1>

      <p>
        Our team of certified mechanics provides top-notch auto repair services.
        We ensure your vehicle gets the best care with modern tools and expertise.
      </p>

      <div class="hero-buttons">
        <a href="/service" class="btn-primary">Book Services</a>
        <a href="/about" class="btn-secondary">Learn More</a>
      </div>

    </div>
  </div>
</section>




</body>
</html>